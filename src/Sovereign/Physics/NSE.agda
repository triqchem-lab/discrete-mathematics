-- §1. GF(3) 代数 (穷举证明, 13命题)
--------------------------------------------------------------------------------

add3 : Trit → Trit → Trit
add3 T₀ x = x; add3 T₁ T₀ = T₁; add3 T₁ T₁ = T₂; add3 T₁ T₂ = T₀
add3 T₂ T₀ = T₂; add3 T₂ T₁ = T₀; add3 T₂ T₂ = T₁

add3-comm : (a b : Trit) → add3 a b ≡ add3 b a
add3-comm T₀ T₀ = refl; add3-comm T₀ T₁ = refl; add3-comm T₀ T₂ = refl
add3-comm T₁ T₀ = refl; add3-comm T₁ T₁ = refl; add3-comm T₁ T₂ = refl
add3-comm T₂ T₀ = refl; add3-comm T₂ T₁ = refl; add3-comm T₂ T₂ = refl

add3-assoc : (a b c : Trit) → add3 (add3 a b) c ≡ add3 a (add3 b c)
add3-assoc T₀ T₀ T₀ = refl; add3-assoc T₀ T₀ T₁ = refl; add3-assoc T₀ T₀ T₂ = refl
add3-assoc T₀ T₁ T₀ = refl; add3-assoc T₀ T₁ T₁ = refl; add3-assoc T₀ T₁ T₂ = refl
add3-assoc T₀ T₂ T₀ = refl; add3-assoc T₀ T₂ T₁ = refl; add3-assoc T₀ T₂ T₂ = refl
add3-assoc T₁ T₀ T₀ = refl; add3-assoc T₁ T₀ T₁ = refl; add3-assoc T₁ T₀ T₂ = refl
add3-assoc T₁ T₁ T₀ = refl; add3-assoc T₁ T₁ T₁ = refl; add3-assoc T₁ T₁ T₂ = refl
add3-assoc T₁ T₂ T₀ = refl; add3-assoc T₁ T₂ T₁ = refl; add3-assoc T₁ T₂ T₂ = refl
add3-assoc T₂ T₀ T₀ = refl; add3-assoc T₂ T₀ T₁ = refl; add3-assoc T₂ T₀ T₂ = refl
add3-assoc T₂ T₁ T₀ = refl; add3-assoc T₂ T₁ T₁ = refl; add3-assoc T₂ T₁ T₂ = refl
add3-assoc T₂ T₂ T₀ = refl; add3-assoc T₂ T₂ T₁ = refl; add3-assoc T₂ T₂ T₂ = refl

c3-cw : Trit → Trit
c3-cw T₀ = T₁; c3-cw T₁ = T₂; c3-cw T₂ = T₀

c3-inverse : (t : Trit) → c3-cw (c3-cw (c3-cw t)) ≡ t
c3-inverse T₀ = refl; c3-inverse T₁ = refl; c3-inverse T₂ = refl

