--------------------------------------------------------------------------------
-- 6. 幻方与 T⁶ 环面的关系
--------------------------------------------------------------------------------

-- 144 阶幻方是 T⁶ 环面在二维的投影切片
-- 每个单元格对应 T⁶ 的一个特定格点

magicToT6 : Fin 144 × Fin 144 → T6Lattice
magicToT6 (r , c) =
  fromℕ< (m%n<n (toℕ r) 3)
  ∷ fromℕ< (m%n<n (toℕ c) 3)
  ∷ fromℕ< (m%n<n (toℕ r + toℕ c) 3)
  ∷ fromℕ< (m%n<n (toℕ r) 3)
  ∷ fromℕ< (m%n<n (toℕ c) 3)
  ∷ fromℕ< (m%n<n (toℕ r + toℕ c) 3)
  ∷ []

-- 幻方的周期性边界条件
-- 行/列索引模 144
magicPeriodic : Fin 144 → Fin 144 → Fin 144
magicPeriodic i j = fromℕ< (m%n<n (toℕ i + toℕ j) 144)

